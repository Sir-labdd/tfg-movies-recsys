# Copy this file to .env and adjust values for your environment.

# Database password (used by docker-compose.yml and by the application)
DB_PASSWORD=your_password_here

# Full connection string used by Python scripts and Kotlin services
DATABASE_URL=postgresql://tfg_user:your_password_here@localhost:5432/tfg_movies
DATABASE_JDBC_URL=jdbc:postgresql://localhost:5432/tfg_movies
# Variables expected by server/src/main/resources/application.yaml
DATABASE_USER=tfg_user
DATABASE_PASSWORD=your_password_here
